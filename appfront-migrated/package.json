{
  "name": "MyHANAApp",
  "version": "1.0.0",
  "description": "A simple CAP project.",
  "repository": "<Add your repository here>",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@cap-js/hana": "^2.7.0",
    "@sap/cds": "^9.8.4",
    "@sap/cds-common-content": "^3.1.0",
    "@sap/xssec": "^4",
    "express": "^5"
  },
  "devDependencies": {
    "@cap-js/cds-types": "^0.16.0",
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-interaction_items": "cds watch --open interaction_items/webapp/index.html?sap-ui-xx-viewCache=false",
    "watch-hybrid": "cds watch --profile hybrid",
    "deploy-hana": "cds deploy --to hana:MyHANAApp-db-dev",
    "create-xsuaa": "cf create-service xsuaa application MyHANAApp-auth -c xs-security.json && cds bind --to MyHANAApp-auth",
    "start-router": "cds bind --exec -- npm start --prefix app/router"
  },
  "cds": {
    "requires": {
      "auth": "xsuaa"
    },
    "sql": {
      "native_hana_associations": false
    }
  },
  "sapux": [
    "app/interaction_items"
  ]
}